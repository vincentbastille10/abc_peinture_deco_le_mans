{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "chat.html", "use": "@vercel/static" },
    { "src": "peintre-le-mans.html", "use": "@vercel/static" },
    { "src": "static/**", "use": "@vercel/static" },
    { "src": "api/main.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/chat$", "dest": "/chat.html" },
    { "src": "^/peintre-le-mans$", "dest": "/peintre-le-mans.html" },
    { "src": "^/static/(.*)$", "dest": "/static/$1" },
    { "src": "^/api/(.*)$", "dest": "/api/main.py" }
  ]
}
