{
  "version": 2,
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/chat$",
      "dest": "/chat.html"
    },
    {
      "src": "^/peintre-le-mans$",
      "dest": "/peintre-le-mans.html"
    },
    {
      "src": "^/static/(.*)$",
      "dest": "/static/$1"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/main.py"
    }
  ]
}
